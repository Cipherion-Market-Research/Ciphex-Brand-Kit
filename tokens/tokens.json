{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "CipheX design tokens. Values are transcribed from the CipheX Brand Design Guide (§03 Color, §04 Typography). Primitive tokens hold the raw palette; semantic tokens map roles to primitives via aliases. The guide is the source of truth — if a value here disagrees with it, the guide wins.",

  "color": {
    "$type": "color",

    "brand": {
      "$description": "Institutional blue — one accent, used decisively. Blue marks the things that matter: a link, a metric, the italic phrase in a headline.",
      "blue": {
        "primary": { "$value": "#0050d6", "$description": "Links, CTAs, highlights. The core brand accent." },
        "deep":    { "$value": "#003fa8", "$description": "Hover state, badges." },
        "soft":    { "$value": "#5b9dff", "$description": "Headings on dark grounds." },
        "glow":    { "$value": "#4d8fff", "$description": "Focus rings on dark grounds." }
      }
    },

    "ground": {
      "$description": "Warm cream grounds and panels — never pure white. Light-mode surfaces.",
      "cream":   { "$value": "#fbfaf6", "$description": "Primary light background." },
      "surface": { "$value": "#f0ede4", "$description": "Raised panels on cream." },
      "sand":    { "$value": "#e8e2d6", "$description": "Secondary panels." }
    },

    "ink": {
      "$description": "Warm near-black text colors for use on cream — never pure black.",
      "primary": { "$value": "#1c1e24", "$description": "Headlines / primary text on cream." },
      "body":    { "$value": "#3a3528", "$description": "Body copy." },
      "muted":   { "$value": "#6b6552", "$description": "Secondary text." },
      "subtle":  { "$value": "#756f5e", "$description": "Meta / captions." }
    },

    "dark": {
      "$description": "Near-black grounds with a cool, deep-navy bias — dark-mode surfaces. Text on these is the cream stepped down in opacity (see opacity ramp), never grey.",
      "hero":         { "$value": "#0a0c10", "$description": "Hero / page background." },
      "panel":        { "$value": "#0c0e13", "$description": "Raised panels on dark." },
      "product-hero": { "$value": "#0d0f14", "$description": "Product hero background." },
      "navy-bridge":  { "$value": "#060d1e", "$description": "Navy-biased accent ground." },
      "deepest":      { "$value": "#04080f", "$description": "Deepest ground." }
    },

    "status": {
      "$description": "Functional only — use exclusively in data-viz for their meaning. Never as brand accents; that job belongs to blue alone.",
      "amber":   { "$value": "#d29922", "$description": "Active — 'Preparing Access'." },
      "gold":    { "$value": "#836a1c", "$description": "Legal / important notices." },
      "success": { "$value": "#3fb950", "$description": "Complete · positive delta." },
      "danger":  { "$value": "#c0392b", "$description": "Errors · negative delta." },
      "teal":    { "$value": "#00a67e", "$description": "Data-viz / taxonomy only." },
      "violet":  { "$value": "#5b2be2", "$description": "Data-viz / taxonomy only." }
    }
  },

  "opacity": {
    "$type": "number",
    "$description": "Cream-text opacity ramp on dark grounds. Apply to color.ground.cream — never substitute grey.",
    "text-primary": { "$value": 0.92, "$description": "Headlines." },
    "text-body":    { "$value": 0.72, "$description": "Paragraphs." },
    "text-muted":   { "$value": 0.55, "$description": "Secondary." },
    "text-subtle":  { "$value": 0.45, "$description": "Meta / captions." }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["Geist", "system-ui", "-apple-system", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"], "$description": "Digital voice. Body, UI labels, and the sans lead-in of headlines." },
      "serif": { "$value": ["Merriweather", "Georgia", "Cambria", "Times New Roman", "serif"], "$description": "Traditional-finance voice. The italic emphasis phrase in a headline, editorial titles, large stat figures." },
      "mono": { "$value": ["Geist Mono", "ui-monospace", "SFMono-Regular", "Menlo", "Consolas", "monospace"], "$description": "Terminal voice. Eyebrows / kickers, tags, data labels, dates, meta. Always uppercase." }
    },
    "weight": {
      "$type": "fontWeight",
      "light":     { "$value": 300 },
      "regular":   { "$value": 400 },
      "medium":    { "$value": 500 },
      "semibold":  { "$value": 600, "$description": "Display heading weight." },
      "bold":      { "$value": 700 },
      "extrabold": { "$value": 800 }
    },
    "tracking": {
      "$description": "Letter-spacing. Stored in em as strings for direct CSS use.",
      "display": { "$value": "-0.03em", "$description": "Display headings (Geist 600)." },
      "mono":    { "$value": "-0.14em", "$description": "Geist Mono terminal labels." }
    },
    "leading": {
      "$description": "Line-height (unitless).",
      "display": { "$value": "1.05", "$description": "Display headings (1.05–1.1 range)." }
    }
  },

  "semantic": {
    "$description": "Role-based aliases — prefer these in product code over raw primitives. Light theme is the default; the dark equivalents live in the matching CSS/SCSS theme block.",
    "color": {
      "$type": "color",
      "bg":            { "$value": "{color.ground.cream}",  "$description": "Page background (light)." },
      "bg-raised":     { "$value": "{color.ground.surface}","$description": "Panels (light)." },
      "text":          { "$value": "{color.ink.primary}",   "$description": "Primary text (light)." },
      "text-body":     { "$value": "{color.ink.body}" },
      "text-muted":    { "$value": "{color.ink.muted}" },
      "accent":        { "$value": "{color.brand.blue.primary}", "$description": "Links, CTAs, the one emphatic moment." },
      "accent-hover":  { "$value": "{color.brand.blue.deep}" },
      "focus":         { "$value": "{color.brand.blue.glow}" }
    }
  }
}
